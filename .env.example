# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-key
SUPABASE_ANON_KEY=tu-anon-key

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+57xxxxxxxxxx
META_PHONE_NUMBER=57xxxxxxxxxx

# API
PORT=3000
API_URL=https://tu-dominio.com
NODE_ENV=development

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxx
FROM_EMAIL=drogueria@tudominio.com

# Admin
ADMIN_EMAIL=admin@drogueriavirtual.com
ADMIN_PASSWORD_HASH=
ADMIN_WHATSAPP=3001234567       # Recibe alertas operativas por WhatsApp
SOCIO_EMAIL=socio@distribuidor.co  # Recibe liquidaciones mensuales

# Monitoreo (Sentry — opcional pero recomendado en prod)
# Crear cuenta en sentry.io y obtener DSN del proyecto
SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXX

# JWT
JWT_SECRET=tu-secreto-muy-seguro

# Pagos (Nequi / Daviplata) — modo legacy / fallback
NEQUI_NUMERO=3001234567
DAVIPLATA_NUMERO=3001234567
NOMBRE_CUENTA=Droguería Virtual SAS

# Pagos Wompi (modo recomendado para producción)
# Obtener credenciales en: https://comercios.wompi.co
# Si las llaves están vacías, el bot usa el modo legacy.
WOMPI_API_URL=https://production.wompi.co/v1
WOMPI_PUBLIC_KEY=pub_prod_xxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_prod_xxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_KEY=prod_integrity_xxxxxxxxxxxx
WOMPI_EVENTS_SECRET=prod_events_secret_xxxxxx

# Domicilio
COSTO_DOMICILIO=4000
